generator client { provider = "prisma-client-js" }
datasource db { provider = "sqlite"; url = env("DATABASE_URL") }
enum Role { ADMIN FINANCE SUPPORT VIEWER }
enum InvoiceStatus { DRAFT SENT PAID VOID OVERDUE }
enum TransactionStatus { REQUIRES_PAYMENT PENDING SUCCEEDED FAILED REFUNDED }
model Workspace { id String @id @default(cuid()); name String; legalName String?; testMode Boolean @default(true); createdAt DateTime @default(now()); users User[]; customers Customer[]; invoices Invoice[]; paymentLinks PaymentLink[]; transactions Transaction[] }
model User { id String @id @default(cuid()); email String @unique; name String; role Role @default(VIEWER); workspaceId String; workspace Workspace @relation(fields:[workspaceId],references:[id]); auditLogs AuditLog[]; createdAt DateTime @default(now()) }
model Customer { id String @id @default(cuid()); workspaceId String; workspace Workspace @relation(fields:[workspaceId],references:[id]); email String; name String; company String?; phone String?; metadata Json?; invoices Invoice[]; transactions Transaction[]; createdAt DateTime @default(now()); @@unique([workspaceId,email]) }
model Invoice { id String @id @default(cuid()); workspaceId String; workspace Workspace @relation(fields:[workspaceId],references:[id]); customerId String; customer Customer @relation(fields:[customerId],references:[id]); number String; status InvoiceStatus @default(DRAFT); currency String @default("usd"); subtotal Int; tax Int @default(0); total Int; dueAt DateTime?; lineItems Json; createdAt DateTime @default(now()); @@unique([workspaceId,number]) }
model PaymentLink { id String @id @default(cuid()); workspaceId String; workspace Workspace @relation(fields:[workspaceId],references:[id]); slug String @unique; title String; amount Int; currency String @default("usd"); active Boolean @default(true); providerRef String?; createdAt DateTime @default(now()) }
model Transaction { id String @id @default(cuid()); workspaceId String; workspace Workspace @relation(fields:[workspaceId],references:[id]); customerId String?; customer Customer? @relation(fields:[customerId],references:[id]); provider String; providerRef String @unique; amount Int; fee Int?; currency String; status TransactionStatus; metadata Json?; createdAt DateTime @default(now()) }
model AuditLog { id String @id @default(cuid()); actorId String?; actor User? @relation(fields:[actorId],references:[id]); workspaceId String; action String; entityType String?; entityId String?; ipHash String?; metadata Json?; createdAt DateTime @default(now()); @@index([workspaceId,createdAt]) }
